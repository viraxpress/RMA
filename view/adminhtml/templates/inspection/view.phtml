<script>
    require(['jquery', 'Magento_Ui/js/modal/alert', 'Magento_Ui/js/modal/confirm'], function ($, alert, confirm) {
        $('#rma-back').on('click', function () {
            var backUrl = "<?= $escaper->escapeUrl($block->getUrl('vx_rma/config/index')) ?>";
            window.location.href = backUrl;
        }); 

        function showLoaderAndReload() {
            $('body').trigger('processStart');
            setTimeout(function () {
                location.reload();
            }, 300);
        }

        function showAlert(title, content, callback) {
            alert({
                title: $.mage.__(title),
                content: $.mage.__(content),
                actions: {
                    always: callback || function () {}
                }
            });
        }

        function updateRmaItemStatus(itemId, rmaId, status) {
            $.ajax({
                url: '<?= $escaper->escapeUrl($block->getUrl("vx_rma/rma/updateitemstatus")) ?>',
                type: 'POST',
                data: {
                    item_id: itemId,
                    rma_id: rmaId,
                    status: status,
                    form_key: window.FORM_KEY
                },
                success: function (response) {
                    if (response.success) {
                        showAlert('Success', 'Item status updated successfully.', showLoaderAndReload);
                    } else {
                        showAlert('Error', response.message);
                    }
                },
                error: function () {
                    showAlert('Error', 'Failed to update item status. Try again.');
                }
            });
        }


        $('.item_status').on('change', function () {
            var itemId = $(this).data('item-id');
            var rmaId = $(this).data('rma-id');
            var status = $(this).val();
                updateRmaItemStatus(itemId, rmaId, status);
        });

        $('#save-inspection').on('click', function () {
            var data = {
                inspection_id: $('[name="inspected_by"]').data('inspection-id'),
                inspected_by: $('[name="inspected_by"]').val(),
                inspected_at: $('[name="inspected_at"]').val(),
                refurbished_notes: $('[name="refurbished_notes"]').val(),
                scrap_reason: $('[name="scrap_reason"]').val(),
                test_results: $('[name="test_results"]').val(),
                action_taken: $('[name="action_taken"]').val(),
                restock: $('[name="restock"]').val(),
                inspection_status: $('[name="inspection_status"]').val()
            };
            $.ajax({
                url: '<?= $escaper->escapeUrl($block->getUrl("vx_rma/iteminspection/updateinspection")) ?>',
                type: 'POST',
                data: data,
                showLoader: true,
                success: function (response) {
                    if (response.success) {
                        showAlert('Success', 'Inspection status updated successfully.', showLoaderAndReload);
                    } else {
                        showAlert('Error', response.message);
                    }
                },
                error: function (xhr, status, error) {
                    alert('AJAX error: ' + error);
                }
            });
        });


    });
</script>
