<script>
        require([
                'jquery',
                'Magento_Ui/js/modal/modal',
                'Magento_Ui/js/modal/alert',
                'mage/loader',
                'Magento_Ui/js/form/element/file-uploader',
            ], function ($, modal, alert) {
                
                $(document).on('click', '#rma-save', function (e) {
                    var form = $('#return-form');
                    var orderId = <?= $escaper->escapeJs($order->getId())?>;
                    var selectedItems = [];
                    var rmaStatus=$('#rma_status').val();
                    const requestData = {
                        order_id: orderId,
                        status: rmaStatus,
                        customer_id: "<?= $escaper->escapeJs($order->getCustomerId()); ?>",
                        customer_email: "<?= $escaper->escapeJs($order->getCustomerEmail()); ?>",
                        customer_name: "<?= $escaper->escapeJs($order->getCustomerFirstname() . ' ' .
                                            $order->getCustomerLastname()); ?>"
                    };

                    form.find('.item-checkbox:checked').each(function () {
                        const itemId = $(this).data('item-id'); 
                        const productId = $(this).data('product-id');
                        const qty = parseInt($(`[name="qty_returned[${itemId}]"]`).val(), 10) || 0;
                        const reason = $(`[name="reason[${itemId}]"]`).val() || '';
                        const condition = $(`[name="condition[${itemId}]"]`).val() || '';
                        const resolutions = $(`[name="solution[${itemId}]"]`).val() || '';


                        const fileInput = $(`#custom-uploader-${itemId}`).find('.file-name-input');
                        let uploadedImages = [];
                        try {
                            const val = fileInput.val();
                            if (val) {
                                uploadedImages = JSON.parse(val);
                            }
                        } catch (e) {
                            console.error('Failed to parse uploaded image data for item ID ' + itemId, e);
                        }

                        selectedItems.push({
                            product_id: productId,
                            qty_requested: qty,
                            qty_received: 0,
                            reason: reason,
                            condition: condition,
                            resolutions: resolutions,
                            status: "Pending",
                            images: uploadedImages
                        });
                    });
                    if (!selectedItems.length) {
                        alert({
                            title: $.mage.__('Validation Error'),
                            content: $.mage.__('Please select at least one item to return.')
                        });
                        return;
                    }

                    const finalData = {
                        request: requestData,
                        items: selectedItems,
                    };

                    $('body').loader('show');
                    $.ajax({
                        url: `<?= $escaper->escapeUrl($block->getUrl("vx_rma/rma/save")) ?>
                        ?form_key=<?= $escaper->escapeUrl($block->getFormKey()) ?>`,

                        type: 'POST',
                        data: JSON.stringify(finalData),
                        contentType: 'application/json',
                        dataType: 'json',
                        showLoader: true,
                        success: function (response) {
                            if (response.success) {
                                setTimeout(function () {
                                    $('body').loader('hide');
                                    alert({
                                        title: $.mage.__('Success'),
                                        content: $.mage.__('Return request submitted successfully.'),
                                        actions: {
                                            always: function () {
                                                window.location.href ="<?= $escaper->escapeUrl($block->getUrl('vx_rma/rma/index')) ?>";
                                            }
                                        }
                                    });
                                }, 1000);
                            }
                            else {
                                $('body').loader('hide');
                                alert({
                                    title: $.mage.__('Error'),
                                    content: response.message || $.mage.__('Something went wrong.')
                                });
                            }
                        },
                        error: function (xhr) {
                            $('body').loader('hide');
                            alert({
                                title: $.mage.__('AJAX Error'),
                                content: $.mage.__('AJAX error: ') + xhr.status + ' - ' + xhr.statusText
                            });
                        }
                    });
                });

                $(document).on('change', '.item-checkbox', function () {
                    const itemId = $(this).data('item-id');

                    const inputs = $(`.item-inputs-${itemId} input, .item-inputs-${itemId} select`);

                    if (this.checked) {
                        inputs.prop('disabled', false);
                    } else {
                        inputs.prop('disabled', true);
                        inputs.filter('.qty-error').text('');
                    }
                });
                
                function validateAllReturnQtyInputs() {
                    let hasErrors = false;

                    $('.qty-returned').each(function () {
                        const $input = $(this);
                        const itemId = $(this).data('item-id');
                        const val = parseInt($input.val(), 10);
                        const min = parseInt($input.attr('min'), 10) || 1;
                        const max = parseInt($input.attr('max'), 10);
                        const returnable = parseInt($input.data('returnable'), 10);
                        const $errorTooltip = $input.closest('.qty-wrapper').find('.qty-error-tooltip');
                        const $checkbox   = $('.item-checkbox[data-item-id="' + itemId + '"]');
                            if (!$checkbox.prop('checked')) {
                                $errorTooltip.hide();
                                return;
                            }
                        let errorMsg = '';
                        if (isNaN(val) || val < min) {
                            errorMsg = `Minimum quantity is ${min}`;
                        }
                        else if (val > returnable) {
                            errorMsg = `Only ${returnable} item(s) available for return`;
                        } else if (val > max) {
                            errorMsg = `Cannot exceed ordered quantity (${max})`;
                        }

                        if (errorMsg) {
                            hasErrors = true;
                            $errorTooltip.text(errorMsg).show();
                        } else {
                            $errorTooltip.hide();
                        }
                    });

                    $('#rma-save').prop('disabled', hasErrors);
                }

                $(document).on('input change keyup', '.qty-returned', function () {
                    validateAllReturnQtyInputs();
                });

                // Trigger once initially
                validateAllReturnQtyInputs();
                //Image Uploader
                $(document).ready(function () {
                    $('.item-inputs input, .item-inputs select').prop('disabled', true);
                    const uploadedImagesMap = {};

                    // Handle new file uploads
                    const MAX_FILE_SIZE = <?= $escaper->escapeJs(
                        $block->getMaxFileSize()
                    ) * 1024 * 1024 ?>; 
                    const ALLOWED_EXTENSIONS = <?=  /** noescape */json_encode($block->getAllowedFileTypes()) ?>;
                    const MAX_FILE_COUNT = <?= (int)$block->getMaxFileCount() ?>;
                    function handleFiles(files, preview, key) {
                        if (!uploadedImagesMap[key]) {
                            uploadedImagesMap[key] = [];
                        }

                        const uploader = $('#' + key);
                        const fileNameInput = uploader.find('.file-name-input');

                        const existingCount = uploadedImagesMap[key].length;
                        const remainingSlots = MAX_FILE_COUNT - existingCount;

                        const validFiles = [];

                        // Filter valid files and enforce count limit
                        for (let i = 0; i < files.length; i++) {
                            const file = files[i];

                            if (validFiles.length >= remainingSlots) {
                                alert({
                                    title: $.mage.__('Maximum Upload Limit Reached'),
                                    content: $.mage.__(`You can upload up to ${MAX_FILE_COUNT} files.`)
                                });
                                break;
                            }

                            const extension = file.name.split('.').pop().toLowerCase();
                            const isAllowed = ALLOWED_EXTENSIONS.includes(extension);

                            if (!isAllowed) {
                                alert({
                                    title: $.mage.__(`Invalid File Type: ${file.name}`),
                                    content: $.mage.__(`Allowed types: ${ALLOWED_EXTENSIONS.join(', ')}`)
                                });
                                continue;
                            }

                            if (file.size > MAX_FILE_SIZE) {
                                alert({
                                    title: $.mage.__(`File too large: ${file.name}`),
                                    content: $.mage.__(`Max allowed size is ${Math.round(MAX_FILE_SIZE / 1024 / 1024)}MB`)
                                });
                                continue;
                            }

                            validFiles.push(file);
                        }

                        // Now process only the validated files
                        validFiles.forEach(file => {
                            const reader = new FileReader();
                            reader.onload = function (e) {
                                const imageData = e.target.result;

                                if (uploadedImagesMap[key].some(item => item.data === imageData)) return;

                                uploadedImagesMap[key].push({
                                    data: imageData,
                                    name: file.name
                                });
                                if (uploadedImagesMap[key].length >= MAX_FILE_COUNT) {
                                    uploader.find('.upload-input').prop('disabled', true).addClass('disabled');
                                }

                                const imgWrapper = $('<div>').css('position', 'relative');
                                let previewElement;

                                if (['jpg', 'jpeg', 'png', 'gif', 'bmp', 'webp'].includes(file.name.split('.').pop().toLowerCase())) {
                                    previewElement = $('<img>')
                                        .attr('src', imageData)
                                        .addClass('preview-content');
                                } else if (file.name.split('.').pop().toLowerCase() === 'pdf') {
                                    previewElement = $('<embed>')
                                        .attr('src', imageData)
                                        .attr('type', 'application/pdf')
                                        .addClass('preview-content');
                                } else {
                                    previewElement = $('<div>').addClass('preview-fallback')
                                        .text(file.name);
                                }

                                const removeBtn = $('<button>')
                                    .addClass('remove-btn')
                                    .html('&times;')
                                    .on('click', function () {
                                        const index = uploadedImagesMap[key].findIndex(img => img.data === imageData);
                                        if (index > -1) uploadedImagesMap[key].splice(index, 1);
                                        imgWrapper.remove();

                                        const updatedNames = uploadedImagesMap[key];
                                        fileNameInput.val(JSON.stringify(updatedNames));
                                        if (uploadedImagesMap[key].length < MAX_FILE_COUNT) {
                                            uploader.find('.upload-input').prop('disabled', false).removeClass('disabled');
                                        }
                                    });

                                imgWrapper.append(previewElement).append(removeBtn);
                                preview.append(imgWrapper);
                                fileNameInput.val(JSON.stringify(uploadedImagesMap[key]));
                            };
                            reader.readAsDataURL(file);
                        });
                    }
                      // Handle input change via delegation
                    $(document).on('change', '.rma-item-image-container .upload-input', function (e) {
                        const uploader = $(this).closest('.rma-item-image-container');
                        const preview = uploader.find('.upload-preview');
                        const uploaderId = uploader.attr('id');
                        handleFiles(e.target.files, preview, uploaderId);
                        $(this).val('');
                    });

                    $(document).on('dragover', '.custom-uploader .upload-dropzone', function (e) {
                        e.preventDefault();
                        e.stopPropagation();
                        $(this).addClass('dragover');
                    });

                    $(document).on('dragleave', '.custom-uploader .upload-dropzone', function (e) {
                        e.preventDefault();
                        e.stopPropagation();
                        $(this).removeClass('dragover');
                    });

                    $(document).on('drop', '.rma-item-image-container .upload-dropzone', function (e) {
                        e.preventDefault();
                        e.stopPropagation();
                  