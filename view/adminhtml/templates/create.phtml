<script>
    require(['jquery',
            'mage/url',
            'Magento_Ui/js/modal/alert',
            'Magento_Ui/js/modal/modal',
            'mage/loader'], 
        function ($, urlBuilder,alert,modal) {

        $('#rma-reset').on('click', function(){
            location.reload();
        })
        $('#rma-back').on('click', function () {
            var backUrl = "<?= $escaper->escapeUrl($block->getUrl('vx_rma/rma/index')) ?>";
            window.location.href = backUrl;
        });
        $('#load-order').on('click', function () {
            $('body').loader('show');
            const $errorTooltip = $('.error-tooltip');
            const IncrementId = $('#increment_id').val();
            if (!IncrementId) {
                setTimeout(() => {
                    $errorTooltip.text("Increment id required").show();
                    $('body').loader('hide');
                }, 1000);
                return;
            };
            
            $.ajax({
                url: '<?= $escaper->escapeUrl($block->getLoadUrl()) ?>',
                type: 'POST',
                data: { increment_id: IncrementId },
                success: function (res) {
                    if (res.success) {
                        $errorTooltip.text("").hide();
                        $('body').loader('hide');
                        // alert({
                        //         title: $.mage.__('Order Load Error'),
                        //         content: $.mage.__(res.html)
                        //     });
                        $('#rma-items-grid').html(res.html);
                        $('#customer-info').show();
                        $('#customer-info-email').show();
                        $('#customer-name').text(res.customer_name || '');
                        $('#customer-email').text(res.customer_email || '');
                    } else {
                        alert({
                                title: $.mage.__('Order Load Error'),
                                content: $.mage.__(res.message)
                            });
                    }
                }
            });
        });
        $(document).on('click', '.order-table-select-row', function () {
            let incrementId = $(this).data('order-id');
            $('#increment_id').val(incrementId);
            $('#rma-items-grid').html('');
            $('#customer-info').hide();
            $('#customer-name').text('');
            orderModal.closeModal();
        });

        var orderModal = modal({
            title: 'Return Orders',
            type: 'slide',
            modalClass: 'order-modal',
            responsive: true,
            buttons: [] 
        }, $('#order-modal'));

        $('#select-order').on('click',function(){
            orderModal.openModal();
        })

        function reloadGrid(url, data = null, updateUrl = true) {
            $.ajax({
                url: url,
                type: data ? 'POST' : 'GET',
                data: data,
                showLoader: true,
                success: function (response) {
                    const html = $(response).find('#order-grid-container').html();
                    $('#order-grid-container').html(html);

                    if (updateUrl) {
                        // Update browser URL without page reload
                        const newUrl = url + (data ? ('?' + data) : '');
                        window.history.pushState({}, '', newUrl);
                    }
                },
                error: function () {
                    alert('Failed to reload the grid.');
                }
            });
        }

        $(document).on('submit', '#order-grid-form', function (e) {
            e.preventDefault();
            const form = $(this);
            reloadGrid(form.attr('action'), form.serialize());
        });

        $(document).on('click', '.admin__data-grid-pager a', function (e) {
            e.preventDefault();
            reloadGrid($(this).attr('href'), null);
        });

        $(document).on('change', 'select[name="limit"]', function () {
            $('#order-grid-form').submit();
        });

        $(document).on('click', '.reset-filter', function (e) {
            e.preventDefault();
            reloadGrid($(this).attr('href'), null);
        });
        $(document).on('click', '.data-grid-th', function () {
            const url = $(this).data('sort-url');
            if (url) {
                reloadGrid(url);
            }
        });
    });
</script>
