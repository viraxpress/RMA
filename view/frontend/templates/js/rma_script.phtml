    /** @var \ViraXpress\Rma\Block\RmaDetails $block */

    $formKey        = $block->getFormKey();
    $cancelUrl      = $block->getUrl("vx_rma/rma/cancel");
    $itemCancelUrl  = $block->getUrl("vx_rma/rma/itemcancel");
    $filterUrl      = $block->getUrl("vx_rma/rma/filter");
?>

<script>
    // Utility functions
    function debounce(func, wait) {
        let timeout;
        return function executedFunction(...args) {
            const later = () => {
                clearTimeout(timeout);
                func(...args);
            };
            clearTimeout(timeout);
            timeout = setTimeout(later, wait);
        };
    }

    function rmaComponent() {
        return {
            // Initial data from server
            initialData: <?= /** noescape */ $block->safeJson($block->getCompiledData()) ?>,
            data: <?= /** noescape */ $block->safeJson($block->getCompiledData()) ?>,
            // Server endpoints
            cancelUrl: '<?= $escaper->escapeJs($cancelUrl) ?>',
            itemCancelUrl: '<?= $escaper->escapeJs($itemCancelUrl) ?>',
            filterUrl: '<?= $escaper->escapeJs($filterUrl) ?>',
            formKey: '<?= $escaper->escapeJs($formKey) ?>',
            // State management
            search: '',
            page: 1,
            pageSize: 5,
            sortKey: 'created_at',
            sortDir: 'desc',
            // Hybrid mode controls
            isServerMode: false,
            isLoading: false,
            serverResults: null,
            totalServerRecords: 0,
            // Performance thresholds
            CLIENT_THRESHOLD: 500,    // Switch to server mode after 500 records
            SEARCH_MIN_LENGTH: 1,     // Minimum search length for server query
            DEBOUNCE_DELAY: 300,      // Search debounce delay
            // UI state
            showModal: false,
            selectedRma: {},
            confirmModal: {
                show: false,
                title: '',
                message: '',
                resolve: () => {},
                reject: () => {}
            },

            init() {
                this.loadUrlParams();
                this.setupWatchers();
                this.determineMode();
            },

            loadUrlParams() {
                const params = new URLSearchParams(window.location.search);
                this.search = params.get('search') ?? '';
                this.page = parseInt(params.get('page')) || 1;
                this.pageSize = parseInt(params.get('pageSize')) || 5;
                this.sortKey = params.get('sortKey') || 'created_at';
                this.sortDir = params.get('sortDir') || 'desc';
            },

            setupWatchers() {
                // Debounced search watcher
                this.$watch('search', debounce(() => {
                    this.page = 1;
                    this.handleSearchChange();
                }, this.DEBOUNCE_DELAY));
                // Immediate watchers for pagination/sorting
                this.$watch('pageSize', () => {
                    this.page = 1;
                    this.handleDataChange();
                });
                this.$watch('page', () => this.updateUrl());
                this.$watch('sortKey', () => this.handleDataChange());
                this.$watch('sortDir', () => this.handleDataChange());
            },

            determineMode() {
                // Switch to server mode if dataset is large or search is active
                this.isServerMode = this.shouldUseServerMode();
                if (this.isServerMode && this.search.length >= this.SEARCH_MIN_LENGTH) {
                    this.fetchServerData();
                }
            },

            shouldUseServerMode() {
                return this.initialData.length > this.CLIENT_THRESHOLD ||
                (this.search.length >= this.SEARCH_MIN_LENGTH && this.initialData.length > 100);
            },

            handleSearchChange() {
                const newMode = this.shouldUseServerMode();
                if (newMode !== this.isServerMode) {
                    this.isServerMode = newMode;
                }
                if (this.isServerMode && this.search.length >= this.SEARCH_MIN_LENGTH) {
                    this.fetchServerData();
                } else if (this.isServerMode && this.search.length < this.SEARCH_MIN_LENGTH) {
                    // Reset to initial data for short searches
                    this.serverResults = null;
                    this.data = this.initialData;
                    this.isServerMode = false;
                }
                this.updateUrl();
            },

            handleDataChange() {
                if (this.isServerMode) {
                    this.fetchServerData();
                } else {
                    this.updateUrl();
                }
            },

            async fetchServerData() {
                if (this.isLoading) return;
                this.isLoading = true;
                try {
                    const params = new URLSearchParams({
                        search: this.search,
                        page: this.page,
                        pageSize: this.pageSize,
                        sortKey: this.sortKey,
                        sortDir: this.sortDir,
                        form_key: this.formKey
                    });

                    const response = await fetch(this.filterUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'X-Requested-With': 'XMLHttpRequest',
                            'X-Magento-Form-Key': this.formKey
                        },
                        body: params
                    });

                    if (!response.ok) {
                        throw new Error('Server request failed');
                    }

                    const result = await response.json();
                    if (result.success) {
                        this.serverResults = result.data;
                        this.totalServerRecords = result.total || 0;
                        this.data = result.data; // Update display data
                    } else {
                        throw new Error(result.message || 'Server filtering failed');
                    }
                } catch (error) {
                    console.error('Server filtering error:', error);
                    displayMessages([{text: 'Failed to filter data. Switching to client mode.',type: "error"}]);
                    // Fallback to client mode
                    this.isServerMode = false;
                    this.serverResults = null;
                    this.data = this.initialData;
                } finally {
                    this.isLoading = false;
                    this.updateUrl();
                }
            },

            get filtered() {
                // Server mode: return data as-is (already filtered by server)
                if (this.isServerMode && this.serverResults) {
                    return this.data;
                }
                // Client mode: filter locally
                const q = this.search.toLowerCase();
                return this.data
                    .filter(r =>
                        !q || // Empty search returns all
                        String(r.rma_id).toLowerCase().includes(q) ||
                        String(r.order_id).toLowerCase().includes(q) ||
                        String(r.status).toLowerCase().includes(q)
                    )
                    .sort((a, b) => {
                        let x = a[this.sortKey];
                        let y = b[this.sortKey];

                        if (['rma_id', 'order_id'].includes(this.sortKey)) {
                            x = Number(x);
                            y = Number(y);
                        }

                        return this.sortDir === 'asc'
                            ? (x > y ? 1 : x < y ? -1 : 0)
                            : (x < y ? 1 : x > y ? -1 : 0);
                    });
            },

            get totalPages() {
                if (this.isServerMode) {
                    return Math.ceil(this.totalServerRecords / this.pageSize);
                }
                return Math.ceil(this.filtered.length / this.pageSize);
            },

            get paginated() {
                // Server mode: data is already paginated
                if (this.isServerMode) {
                    return this.filtered;
                }

                // Client mode: paginate locally
                const start = (this.page - 1) * this.pageSize;
                return this.filtered.slice(start, start + this.pageSize);
            },

            get totalRecords() {
                return this.isServerMode ? this.totalServerRecords : this.filtered.length;
            },

            sortBy(key) {
                if (this.sortKey === key) {
                    this.sortDir = this.sortDir === 'asc' ? 'desc' : 'asc';
                } else {
                    this.sortKey = key;
                    this.sortDir = 'asc';
                }
            },

            goToPage(i) {
                this.page = Number(i);
            },

            nextPage() {
                if (this.page < this.totalPages) this.page++;
            },

            prevPage() {
                if (this.page > 1) this.page--;
            },

            updateUrl() {
                const params = new URLSearchParams();

                if (this.search.trim() !== '') params.set('search', this.search.trim());
                if (this.page > 1) params.set('page', this.page);
                if (this.pageSize !== 5) params.set('pageSize', this.pageSize);
                if (this.sortKey !== 'created_at') params.set('sortKey', this.sortKey);
                if (this.sortDir !== 'desc') params.set('sortDir', this.sortDir);

                const newUrl = `${window.location.pathname}?${params.toString()}`;
                history.replaceState(null, '', newUrl);
            },

            openItemsModal(rma) {
                this.selectedRma = rma;
                this.showModal   = true;
            },

            confirmDialog(title, message) {
                return new Promise((resolve, reject) => {
                    this.confirmModal.title = title;
                    this.confirmModal.message = message;
                    this.confirmModal.show = true;

                    this.confirmModal.resolve = () => {
                        this.confirmModal.show = false;
                        resolve(true);
                    };

                    this.confirmModal.reject = () => {
                        this.confirmModal.show = false;
                        reject(false);
                    };
                });
            },

            async cancelRma(id) {
                try {
                    await this.confirmDialog("Cancel Return Request",
                        "Are you sure you want to cancel this entire return request?");

                    const res = await fetch(this.cancelUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'X-Requested-With': 'XMLHttpRequest',
                            'X-Magento-Form-Key': this.formKey
                        },
                        body: new URLSearchParams({ rma_id: id })
                    });

                    const json = await res.json();

                    if (!json.success) {
                        throw new Error(json.message || 'Request failed');
                    }
                    displayMessages([{text:  json.message,type: "success"}]);
                    setTimeout(() => location.reload(), 1500);

                } catch (err) {
                    if (err) {
                        displayMessages([{text: err ,type: "error"}]);
                    }
                }
            },

            async cancelItem(itemId) {
                try {
                    await this.confirmDialog("Cancel Item", "Are you sure you want to cancel this item?");

                    const res = await fetch(this.itemCancelUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'X-Requested-With': 'XMLHttpRequest',
                            'X-Magento-Form-Key': this.formKey
                        },
                        body: new URLSearchParams({ rma_item_id: itemId })
                    });

                    if (!res.ok) {
                        const json = await res.json();
                        throw new Error(json.message || 'Request failed');
                    }
                    displayMessages([{text: 'Item cancelled successfully' ,type: "success"}]);
                    setTimeout(() => location.reload(), 1500);

                } catch (err) {
                    if (err) {
                        displayMessages([{text: err ,type: "error"}]);
                    }
                }
            },

            // File helper methods
            previewFile(url) {
                window.open(url, '_blank');
            },

            isImage(url) {
                return /\.(jpg|jpeg|png|gif|bmp|webp)$/i.test(url);
            },

            isPdf(url) {
                return /\.pdf$/i.test(url);
            },

            isOther(url) {
                return !this.isImage(url) && !this.isPdf(url);
            },

            getFileName(url) {
                try {
                    return decodeURIComponent(url.split('/').pop().split('?')[0]);
                } catch {
                    return 'file';
                }
            }
        };
    }
</script>