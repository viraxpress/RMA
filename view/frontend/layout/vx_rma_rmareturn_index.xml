<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="2columns-left"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="customer_account"/>
    <body>
        <referenceBlock name="main">
            <block class="Magento\Theme\Block\Html\Title" name="page.main.title" template="Magento_Customer::html/title.phtml" before="-">
                <action method="setPageTitle">
                    <argument translate="true" name="title" xsi:type="string">Refund/Replacement Requests</argument>
                </action>
            </block>
        </referenceBlock>
        <referenceContainer name="content">
            <block class="ViraXpress\Rma\Block\ReturnOrders" name="return_orders_block" template="ViraXpress_Rma::return.phtml" cacheable="false"/>
        </referenceContainer>
        <referenceContainer name="before.body.end">
            <block class="ViraXpress\Rma\Block\ReturnOrders" name="return_script" template="ViraXpress_Rma::js/return_script.phtml"/>
        </referenceContainer>
    </body>
</page>
