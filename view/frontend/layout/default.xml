<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="footer_links">
            <block class="Magento\Framework\View\Element\Html\Link" name="rma_guest_lookup_link" ifconfig="rma/general/enable">
                <arguments>
                    <argument name="label" translate="true" xsi:type="string">Guest Order Return</argument>
                    <argument name="path" xsi:type="string">vx_rma/guest/index</argument>
                </arguments>
            </block>
        </referenceBlock>
    </body>
</page>